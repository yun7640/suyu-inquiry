<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>수유역 2층 상가 임대 · 도봉로87길 8</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=IBM+Plex+Sans+KR:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#14151a;
    --paper:#f5f2ea;
    --panel:#ffffff;
    --line:#e4ded0;
    --brand:#0e5c4a;      /* deep arcade green */
    --accent:#ff5a3c;     /* neon coin-red */
    --amber:#f2b705;
    --mut:#6b6b60;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:'IBM Plex Sans KR',system-ui,sans-serif;
    background:var(--paper);color:var(--ink);line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:960px;margin:0 auto;padding:0 20px}
  .mono{font-family:'IBM Plex Mono',monospace}

  /* ---------- HERO ---------- */
  header{
    background:
      radial-gradient(120% 80% at 85% -10%, rgba(255,90,60,.16), transparent 55%),
      radial-gradient(90% 70% at -5% 110%, rgba(242,183,5,.16), transparent 55%),
      var(--ink);
    color:#fff;padding:34px 0 44px;position:relative;overflow:hidden;
  }
  .badge{
    display:inline-flex;align-items:center;gap:7px;
    font-size:12.5px;font-weight:600;letter-spacing:.02em;
    border:1px solid rgba(255,255,255,.28);border-radius:100px;
    padding:5px 13px;color:#f3efe6;margin-bottom:22px;
  }
  .dot{width:7px;height:7px;border-radius:50%;background:var(--amber);box-shadow:0 0 0 4px rgba(242,183,5,.22)}
  h1{
    font-family:'Black Han Sans',sans-serif;font-weight:400;
    font-size:clamp(38px,8vw,74px);line-height:.98;letter-spacing:-.01em;
    color:#fff;text-shadow:0 2px 30px rgba(0,0,0,.3);
  }
  h1 .hl{color:var(--amber)}
  .sub{margin-top:16px;font-size:clamp(15px,2.4vw,18px);color:#d9d4c7;max-width:560px}
  .heroline{
    margin-top:26px;display:flex;flex-wrap:wrap;gap:8px;
  }
  .chip{
    font-size:13px;font-weight:500;background:rgba(255,255,255,.09);
    border:1px solid rgba(255,255,255,.16);border-radius:8px;padding:6px 12px;color:#eee;
  }

  /* ---------- KEY TERMS ---------- */
  .terms{
    display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
    background:var(--line);border:1px solid var(--line);border-radius:16px;overflow:hidden;
    margin-top:-30px;position:relative;z-index:3;box-shadow:0 18px 50px -24px rgba(20,21,26,.45);
  }
  .term{background:var(--panel);padding:20px 16px}
  .term .k{font-size:12px;font-weight:600;color:var(--mut);letter-spacing:.02em}
  .term .v{font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:clamp(19px,3vw,25px);margin-top:6px;color:var(--ink)}
  .term .u{font-size:12px;color:var(--mut);font-weight:500}
  .term.hot .v{color:var(--accent)}

  /* ---------- UNITS (2F / 3F) ---------- */
  .units{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:-30px;position:relative;z-index:3}
  .unit{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:20px;box-shadow:0 18px 50px -28px rgba(20,21,26,.4)}
  .unit.soon{background:linear-gradient(180deg,#fffdf5,#fff)}
  .uhead{display:flex;align-items:center;gap:14px;padding-bottom:16px;border-bottom:1px solid var(--line)}
  .ufloor{font-family:'Black Han Sans',sans-serif;font-size:26px;color:#fff;background:var(--accent);width:56px;height:56px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .ufloor.amber{background:var(--amber);color:#3a2c00}
  .utitle{font-weight:700;font-size:16px}
  .ustatus{font-size:12.5px;font-weight:600;margin-top:3px;display:inline-block;padding:2px 9px;border-radius:100px}
  .ustatus.now{background:#e7f4ef;color:var(--brand)}
  .ustatus.later{background:#fbf1d0;color:#8a6d00}
  .urows{margin-top:14px;display:flex;flex-direction:column;gap:10px}
  .urow{display:flex;align-items:baseline;justify-content:space-between}
  .urow span{font-size:13.5px;color:var(--mut);font-weight:500}
  .urow b{font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:22px;color:var(--ink)}
  .urow b i{font-style:normal;font-size:12.5px;color:var(--mut);font-weight:500;margin-left:2px}
  .urow.hot b{color:var(--accent)}
  .urow.hot.amber b{color:#b8860b}
  .combo{display:flex;align-items:center;gap:14px;margin-top:14px;padding:16px 20px;border-radius:14px;
    background:linear-gradient(90deg,rgba(14,92,74,.10),rgba(242,183,5,.10));border:1px solid var(--line);
    text-decoration:none;color:var(--ink);transition:filter .15s}
  .combo:hover{filter:brightness(1.03)}
  .combo-ic{font-size:22px;flex-shrink:0}
  .combo-tx{font-size:14px;line-height:1.55}
  .combo-tx b{color:var(--brand)}
  .combo-ar{margin-left:auto;font-weight:700;font-size:13.5px;color:var(--brand);white-space:nowrap;flex-shrink:0}

  section{padding:52px 0}
  .eyebrow{
    font-family:'IBM Plex Mono',monospace;font-size:12.5px;font-weight:600;
    letter-spacing:.14em;text-transform:uppercase;color:var(--brand);margin-bottom:12px;
  }
  h2{font-size:clamp(22px,4vw,30px);font-weight:700;letter-spacing:-.01em;line-height:1.25}
  .lead{color:#4a4a42;margin-top:12px;font-size:15.5px;max-width:640px}

  /* ---------- STRENGTHS ---------- */
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:26px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:22px}
  .card .n{font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--accent);font-weight:600}
  .card h3{font-size:17px;font-weight:700;margin:8px 0 6px}
  .card p{font-size:14px;color:#54544b}

  /* ---------- STACK (building floors) ---------- */
  .stack{margin-top:26px;border:1px solid var(--line);border-radius:14px;overflow:hidden}
  .floor{display:flex;align-items:center;gap:16px;padding:15px 20px;background:var(--panel);border-bottom:1px solid var(--line)}
  .floor:last-child{border-bottom:0}
  .floor .lv{font-family:'Black Han Sans',sans-serif;font-size:20px;width:52px;color:var(--ink)}
  .floor .use{font-weight:600;font-size:15px}
  .floor .tag{margin-left:auto;font-size:12px;font-weight:600;padding:4px 10px;border-radius:100px}
  .floor.vacant{background:linear-gradient(90deg,rgba(255,90,60,.09),rgba(242,183,5,.07));}
  .floor.vacant .lv{color:var(--accent)}
  .floor.upcoming{background:linear-gradient(90deg,rgba(242,183,5,.10),rgba(242,183,5,.03));}
  .floor.upcoming .lv{color:#b8860b}
  .tag.occ{background:#eceae1;color:#6b6b60}
  .tag.vac{background:var(--accent);color:#fff}
  .tag.soon{background:var(--amber);color:#3a2c00}

  /* ---------- FIT TENANTS ---------- */
  .fits{display:flex;flex-wrap:wrap;gap:9px;margin-top:22px}
  .fit{background:var(--panel);border:1px solid var(--line);border-radius:100px;padding:9px 16px;font-size:14px;font-weight:600}
  .fit span{color:var(--brand)}
  .exclude{margin-top:18px;font-size:13px;color:var(--mut)}
  .exclude b{color:#a3392a}

  /* ---------- SUPPORT ---------- */
  .support{margin-top:24px;display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .sup{background:var(--ink);color:#f3efe6;border-radius:14px;padding:22px}
  .sup .h{font-weight:700;font-size:16px;color:#fff;margin-bottom:6px}
  .sup .h .em{color:var(--amber)}
  .sup p{font-size:13.5px;color:#c9c4b7}

  /* ---------- GALLERY ---------- */
  .gallery{margin-top:24px;display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .gitem{border:1px solid var(--line);border-radius:14px;overflow:hidden;background:var(--panel)}
  .gitem.wide{grid-column:1 / -1}
  .gitem img{width:100%;height:100%;display:block;object-fit:cover;aspect-ratio:4/3}
  .gitem.wide{background:#14151a}
  .gitem.wide img{aspect-ratio:auto;height:auto;max-height:660px;object-fit:contain;margin:0 auto}
  .gitem figcaption{font-size:12.5px;color:var(--mut);padding:9px 13px;font-weight:500}
  /* ---------- PHOTO ---------- */
  .photo{margin:24px 0 0;border:1px solid var(--line);border-radius:16px;overflow:hidden;background:var(--panel)}
  .photo img{width:100%;height:auto;display:block;max-height:560px;object-fit:cover}
  .photo figcaption{font-size:13px;color:var(--mut);padding:12px 18px;font-weight:500}

  /* ---------- MAP ---------- */
  .mapwrap{margin-top:24px;border:1px solid var(--line);border-radius:16px;overflow:hidden;background:var(--panel)}
  .mapwrap iframe{width:100%;height:340px;border:0;display:block;filter:saturate(1.02)}
  .mapbar{display:flex;align-items:center;gap:14px;padding:16px 20px;flex-wrap:wrap}
  .mapbar .pin{font-weight:700;font-size:15px}
  .mapbar .pinsub{font-size:13px;color:var(--mut);margin-top:3px}
  .mapbtn{margin-left:auto;background:var(--ink);color:#fff;text-decoration:none;font-weight:600;font-size:13.5px;border-radius:10px;padding:11px 16px;white-space:nowrap}

  /* ---------- INQUIRY FORM ---------- */
  .iform{margin-top:24px;background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:24px}
  .iform label{display:block;font-size:13px;font-weight:600;color:#3f3f38;margin-bottom:14px}
  .frow{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .iform input,.iform select,.iform textarea{
    width:100%;margin-top:6px;font-family:inherit;font-size:14.5px;color:var(--ink);
    background:#fbfaf6;border:1px solid var(--line);border-radius:10px;padding:11px 13px;font-weight:400;
  }
  .iform input:focus,.iform select:focus,.iform textarea:focus{outline:2px solid var(--brand);border-color:var(--brand);background:#fff}
  .iform textarea{resize:vertical}
  .fnote{font-size:12.5px;color:var(--mut);background:#f2f4f0;border-radius:9px;padding:10px 13px;margin-bottom:16px}
  .fsubmit{
    width:100%;background:var(--brand);color:#fff;border:0;border-radius:11px;
    padding:14px;font-family:inherit;font-size:15.5px;font-weight:700;cursor:pointer;transition:filter .15s;
  }
  .fsubmit:hover{filter:brightness(1.08)}
  .fsubmit:disabled{opacity:.6;cursor:default}
  .fmsg{font-size:14px;font-weight:600;border-radius:10px;padding:12px 14px;margin-bottom:14px}
  .fmsg.ok{background:#e7f4ef;color:#0e5c4a;border:1px solid #bfe0d4}
  .fmsg.err{background:#fdecea;color:#a3392a;border:1px solid #f2c9c2}

  /* ---------- INQUIRY FORM ---------- */
  .iform{margin-top:24px;background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:24px}
  .iform label{display:block;font-size:13px;font-weight:600;color:#3f3f38;margin-bottom:14px}
  .frow{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .iform input,.iform select,.iform textarea{
    width:100%;margin-top:6px;font-family:inherit;font-size:15px;color:var(--ink);
    background:#fbfaf6;border:1px solid var(--line);border-radius:10px;padding:11px 13px;font-weight:400;box-sizing:border-box;
  }
  .iform input:focus,.iform select:focus,.iform textarea:focus{outline:2px solid var(--brand);border-color:var(--brand);background:#fff}
  .iform textarea{resize:vertical}
  .fnote{font-size:12.5px;color:var(--mut);background:#f2f4f0;border-radius:9px;padding:10px 13px;margin-bottom:14px}
  .fmsg{font-size:14px;font-weight:600;border-radius:10px;padding:12px 14px;margin-bottom:14px}
  .fmsg.ok{background:#e7f4ef;color:#0e5c4a;border:1px solid #bfe0d4}
  .fmsg.err{background:#fdecea;color:#a3392a;border:1px solid #f2c9c2}
  .fsubmit{width:100%;background:var(--brand);color:#fff;border:0;border-radius:11px;padding:14px;font-family:inherit;font-size:15.5px;font-weight:700;cursor:pointer;transition:filter .15s}
  .fsubmit:hover{filter:brightness(1.08)}
  .fsubmit:disabled{opacity:.6;cursor:default}

  /* ---------- CTA ---------- */
  .cta{background:var(--brand);color:#fff;border-radius:20px;padding:38px 30px;margin-top:14px;text-align:center;position:relative;overflow:hidden}
  .cta::after{content:"";position:absolute;inset:0;background:radial-gradient(70% 120% at 100% 0,rgba(242,183,5,.25),transparent 60%);pointer-events:none}
  .cta h2{color:#fff}
  .cta p{color:#cfe8df;margin-top:8px;font-size:15px}
  .contact{margin-top:22px;display:inline-flex;flex-wrap:wrap;gap:10px;justify-content:center;position:relative;z-index:2}
  .btn{background:#fff;color:var(--brand);font-weight:700;font-size:15px;border-radius:11px;padding:13px 22px;text-decoration:none;border:0;cursor:pointer}
  .btn.ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5)}
  .fill{color:#bfe4d9;font-size:12.5px;margin-top:14px;position:relative;z-index:2}

  footer{padding:28px 0 40px;text-align:center;color:var(--mut);font-size:12.5px}

  @media(max-width:720px){
    .terms{grid-template-columns:1fr 1fr}
    .units{grid-template-columns:1fr}
    .frow{grid-template-columns:1fr}
    .gallery{grid-template-columns:1fr}
    .frow{grid-template-columns:1fr}
    .combo{flex-wrap:wrap}
    .combo-ar{margin-left:0}
    .grid2,.support{grid-template-columns:1fr}
    .floor .tag{margin-left:auto}
  }
  @media(prefers-reduced-motion:no-preference){
    .reveal{opacity:0;transform:translateY(14px);transition:opacity .6s ease,transform .6s ease}
    .reveal.in{opacity:1;transform:none}
  }
</style>
</head>
<body>

<header>
  <div class="wrap">
    <span class="badge"><span class="dot"></span>즉시 입주 가능 · 임대 문의</span>
    <h1>수유역 7번 출구 먹자골목<br><span class="hl">핵심 상권</span>의 빈자리 (2·3층)</h1>
    <p class="sub">4호선 수유역 7번 출구 인접 · 롯데시네마 852석 도보 3분. 지하1층·1층 오락실과 4층 코인노래방이 채운 유동인구가 흐르는 자리입니다. 2층 즉시 입주, 3층은 10월말 임차 가능.</p>
    <div class="heroline">
      <span class="chip">📍 강북구 도봉로87길 8</span>
      <span class="chip">🚇 수유역 7번 출구 인접</span>
      <span class="chip">2·3층 각 전용 36평</span>
      <span class="chip">🎬 롯데시네마 인접</span>
    </div>
  </div>
</header>

<div class="wrap">
  <div class="units reveal">
    <div class="unit">
      <div class="uhead">
        <div class="ufloor">2F</div>
        <div><div class="utitle">2층 · 전용 36평</div><div class="ustatus now">즉시 입주 가능</div></div>
      </div>
      <div class="urows">
        <div class="urow"><span>보증금</span><b>7,000<i>만원</i></b></div>
        <div class="urow hot"><span>월 임대료</span><b>300<i>만원</i></b></div>
        <div class="urow"><span>관리비</span><b>36<i>만원/월</i></b></div>
      </div>
    </div>
    <div class="unit soon">
      <div class="uhead">
        <div class="ufloor amber">3F</div>
        <div><div class="utitle">3층 · 전용 36평 (미용실)</div><div class="ustatus later">10월말 임차 가능</div></div>
      </div>
      <div class="urows">
        <div class="urow"><span>보증금</span><b>6,000<i>만원</i></b></div>
        <div class="urow hot amber"><span>월 임대료</span><b>260<i>만원</i></b></div>
        <div class="urow"><span>관리비</span><b>36<i>만원/월</i></b></div>
      </div>
    </div>
  </div>
  <a class="combo reveal" href="#inquiry">
    <span class="combo-ic">🔗</span>
    <span class="combo-tx"><b>2·3층 통합 임대도 가능합니다.</b> 각 전용 36평, 통합 시 약 72평 — 대형 매장(스크린골프 복합관, 대형 방탈출 등)에 적합. 조건은 협의 가능합니다.</span>
    <span class="combo-ar">문의 →</span>
  </a>
</div>

<section>
  <div class="wrap">
    <div class="eyebrow reveal">Why here</div>
    <h2 class="reveal">이미 사람이 모이는 층 위,<br>그 동선의 끝자리.</h2>
    <p class="lead reveal">신규 상권을 개척하는 자리가 아닙니다. 아래층·위층이 만들어 둔 여가 목적 방문객을 그대로 흡수하는, 검증된 집객 위의 2층입니다.</p>
    <div class="grid2">
      <div class="card reveal"><div class="n">01</div><h3>7번 출구 · 삼거리 코너</h3><p>4호선 수유역 7번 출구 인접, 삼거리 코너 자리로 시인성이 높습니다. 강북·경기 북부를 잇는 버스 결절점으로 유동이 안정적입니다.</p></div>
      <div class="card reveal"><div class="n">02</div><h3>롯데시네마 852석</h3><p>6개관 강북권 최대 집객 시설이 도보 3분. 영화 전후 대기·여가 수요가 골목으로 유입됩니다.</p></div>
      <div class="card reveal"><div class="n">03</div><h3>여가·뷰티 집적 건물</h3><p>지하1층·1층 오락실, 4층 코인노래방에 3층 미용실·5층 피부관리실까지. 여가와 뷰티 목적 방문객이 상시 드나드는 건물입니다.</p></div>
      <div class="card reveal"><div class="n">04</div><h3>배후 주거 밀집</h3><p>주택가·오피스가 혼재해 평일 상시 수요를 확보. 10~30대 소비층이 두텁습니다.</p></div>
    </div>
  </div>
</section>

<section style="padding-top:0">
  <div class="wrap">
    <div class="eyebrow reveal">Photos</div>
    <h2 class="reveal">건물·공실 사진</h2>
    <p class="lead reveal">삼거리 코너 외관과 실제 공실 내부입니다. 2·3층 모두 3면 통창으로 채광과 간판 노출이 우수하며, 내부에 화장실이 구비되어 있습니다.</p>
    <div class="gallery reveal">
      <figure class="gitem wide">
        <img src="photos/ext-corner.jpg" alt="건물 외관 — 삼거리 코너" loading="lazy">
        <figcaption>외관 · 수유역 7번 출구 인접 삼거리 코너</figcaption>
      </figure>
      <figure class="gitem">
        <img src="photos/f2-a.jpg" alt="2층 공실 내부 — 통창" loading="lazy">
        <figcaption>2층 내부 · 3면 통창, 기둥 최소</figcaption>
      </figure>
      <figure class="gitem">
        <img src="photos/f2-b.jpg" alt="2층 공실 내부 — 화장실 구비" loading="lazy">
        <figcaption>2층 내부 · 화장실 구비</figcaption>
      </figure>
      <figure class="gitem">
        <img src="photos/f3-a.jpg" alt="3층 공실 내부 — 통창" loading="lazy">
        <figcaption>3층 내부 · 코너 통창</figcaption>
      </figure>
      <figure class="gitem">
        <img src="photos/rooftop.jpg" alt="옥상" loading="lazy">
        <figcaption>옥상 · 실외기 공간</figcaption>
      </figure>
    </div>
    <p class="lead reveal" style="font-size:13px;color:var(--mut);margin-top:12px">※ 공실 내부는 원상 상태로, 인테리어 전 이미지입니다. 렌트프리 기간 내 시공 가능합니다.</p>
  </div>
</section>

<section style="padding-top:0">
  <div class="wrap">
    <div class="eyebrow reveal">The building</div>
    <h2 class="reveal">건물 구성 한눈에</h2>
    <div class="stack reveal">
      <div class="floor"><div class="lv">5F</div><div class="use">피부관리실</div><div class="tag occ">운영 중</div></div>
      <div class="floor"><div class="lv">4F</div><div class="use">코인노래방</div><div class="tag occ">운영 중</div></div>
      <div class="floor upcoming"><div class="lv">3F</div><div class="use">미용실 · 전용 36평 · 10월말 임차 가능</div><div class="tag soon">예정 공실</div></div>
      <div class="floor vacant"><div class="lv">2F</div><div class="use">전용 36평 · 임대 문의</div><div class="tag vac">공실</div></div>
      <div class="floor"><div class="lv">1F</div><div class="use">오락실</div><div class="tag occ">운영 중</div></div>
      <div class="floor"><div class="lv">B1</div><div class="use">오락실</div><div class="tag occ">운영 중</div></div>
    </div>
  </div>
</section>

<section style="padding-top:0">
  <div class="wrap">
    <div class="eyebrow reveal">Best fit</div>
    <h2 class="reveal">어울리는 업종</h2>
    <p class="lead reveal">기존 여가시설과 겹치지 않으면서 같은 유동인구를 흡수해, 건물 전체의 놀이·여가 구성을 완성하는 업종입니다.</p>
    <div class="fits">
      <div class="fit"><span>🎮</span> 플스방</div>
      <div class="fit"><span>🔓</span> 방탈출·VR</div>
      <div class="fit"><span>🎯</span> 다트펍</div>
      <div class="fit"><span>🎲</span> 보드게임카페</div>
      <div class="fit"><span>⛳</span> 스크린골프</div>
      <div class="fit"><span>🍿</span> 시네마 연계 F&B</div>
      <div class="fit"><span>📚</span> 무인 스터디카페</div>
      <div class="fit"><span>🎨</span> 실용학원</div>
    </div>
    <p class="exclude reveal">※ 건물 내 업종 중복 방지를 위해 <b>오락실 · 코인노래방 · 인형뽑기 · 스크린야구 · 홀덤펍</b>은 제외합니다.</p>
  </div>
</section>

<section style="padding-top:0">
  <div class="wrap">
    <div class="eyebrow reveal">Support</div>
    <h2 class="reveal">임차 지원 조건</h2>
    <div class="support">
      <div class="sup reveal"><div class="h"><span class="em">렌트프리</span> 1~2개월</div><p>인테리어 기간 임대료 면제로 초기 투자 부담을 낮춥니다. 계약 조건에 따라 협의.</p></div>
      <div class="sup reveal"><div class="h"><span class="em">관리비</span> 3개월 감면</div><p>입점 초기 3개월 관리비를 감면해 드립니다.</p></div>
      <div class="sup reveal"><div class="h"><span class="em">장기계약</span> 우대</div><p>5년 계약 시 조건을 추가로 협의합니다. 안정적 운영을 지원합니다.</p></div>
      <div class="sup reveal"><div class="h"><span class="em">보증금·월세</span> 유연 협의</div><p>업종과 계약 기간에 맞춰 보증금·월세 조정이 가능합니다.</p></div>
    </div>
  </div>
</section>

<section style="padding-top:0">
  <div class="wrap">
    <div class="eyebrow reveal">Location</div>
    <h2 class="reveal">위치</h2>
    <p class="lead reveal">4호선 수유역 7번 출구 인접 · 삼거리 코너. 롯데시네마 수유(도봉로 308)와 한 블록 거리이며, 메가MGC커피·스타벅스·교보문고·GS25가 도보권에 밀집한 번화가입니다.</p>
    <div class="mapwrap reveal">
      <iframe
        title="도봉로87길 8 위치"
        loading="lazy"
        src="https://www.openstreetmap.org/export/embed.html?bbox=127.0224%2C37.6364%2C127.0274%2C37.6400&layer=mapnik&marker=37.63823%2C127.02494">
      </iframe>
      <div class="mapbar">
        <div>
          <div class="pin">📍 서울 강북구 도봉로87길 8</div>
          <div class="pinsub">수유역 7번 출구 인접 · 삼거리 코너 · 롯데시네마 인접 · 주차 미제공(인근 공영·노상 이용)</div>
        </div>
        <a class="mapbtn" href="https://naver.me/F88RkoAE" target="_blank" rel="noopener">네이버 지도에서 열기 →</a>
      </div>
    </div>
  </div>
</section>

<section style="padding-top:0">
  <div class="wrap">
    <div class="cta reveal">
      <h2>이 자리, 검토해 보시겠어요?</h2>
      <p>프랜차이즈 출점 담당자·창업 희망자의 문의를 환영합니다.</p>
      <div class="contact">
        <a class="btn" href="#inquiry">📝 임대 문의 남기기</a>
        <a class="btn ghost" href="tel:00000000000">📞 전화 문의</a>
      </div>
    </div>
  </div>
</section>

<section id="inquiry" style="padding-top:0">
  <div class="wrap">
    <div class="eyebrow reveal">Inquiry</div>
    <h2 class="reveal">임대 문의하기</h2>
    <p class="lead reveal">아래 양식을 작성해 보내주시면 임대인과 담당 중개사에게 직접 전달됩니다. 작성하신 내용은 공개되지 않습니다.</p>
    <form class="iform reveal" id="inquiryForm">
      <div class="frow">
        <label>이름 / 업체명
          <input type="text" name="name" required placeholder="예: 홍길동 / OO프랜차이즈">
        </label>
        <label>연락처
          <input type="text" name="phone" required placeholder="010-0000-0000">
        </label>
      </div>
      <div class="frow">
        <label>이메일
          <input type="email" name="email" placeholder="회신받을 이메일 (선택)">
        </label>
        <label>관심 층
          <select name="floor">
            <option>2층 (즉시 입주)</option>
            <option>3층 (10월말)</option>
            <option>2·3층 통합</option>
          </select>
        </label>
      </div>
      <label>희망 업종
        <input type="text" name="biz" placeholder="예: 방탈출카페, 플스방, 스크린골프 등">
      </label>
      <label>문의 내용
        <textarea name="message" rows="5" required placeholder="문의하실 내용을 자유롭게 적어주세요. (희망 임대 조건, 입주 희망 시기 등)"></textarea>
      </label>
      <div class="fnote">🔒 작성 내용은 공개되지 않으며, 임대인과 담당 중개사에게만 전달됩니다.</div>
      <div id="formMsg" class="fmsg" style="display:none"></div>
      <button type="submit" class="fsubmit">문의 보내기 →</button>
    </form>
  </div>
</section>

<footer>
  <div class="wrap">서울 강북구 도봉로87길 8 · 2층 즉시 입주(전용 36평) · 3층 10월말 임차 가능 · 주차 미제공(인근 공영·노상 이용) · 최종 수정 2026.07.21</div>
</footer>

<script>
  const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.12});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));


  const form=document.getElementById('inquiryForm');
  const msg=document.getElementById('formMsg');
  form.addEventListener('submit', async (e)=>{
    e.preventDefault();
    const btn=form.querySelector('.fsubmit');
    btn.disabled=true; btn.textContent='전송 중...';
    msg.style.display='none';
    const data=Object.fromEntries(new FormData(form).entries());
    try{
      const r=await fetch('/api/inquiries',{
        method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify(data)
      });
      const j=await r.json();
      if(j.ok){
        form.reset();
        msg.className='fmsg ok';
        msg.textContent='✅ 문의가 정상 접수되었습니다. 임대인이 확인 후 연락드립니다.';
      }else{
        msg.className='fmsg err'; msg.textContent='⚠️ '+(j.error||'전송에 실패했습니다.');
      }
    }catch(err){
      msg.className='fmsg err'; msg.textContent='⚠️ 네트워크 오류로 전송에 실패했습니다. 잠시 후 다시 시도해 주세요.';
    }
    msg.style.display='block';
    btn.disabled=false; btn.textContent='문의 보내기 →';
  });
</script>
</body>
</html>
